// prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  googleId            String?   @unique
  avatar              String?
  role                String    @default("user")
  emailVerified       Boolean   @default(false)
  timezone            String?   @default("UTC")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdInitiatives  Initiative[]
  initiativeMembers   InitiativeMember[]
  sentInvitations     InitiativeInvitation[] @relation("InvitationSender")
  createdActions      Action[]
  assignedActions     Action[]               @relation("ActionAssignee")
  actionUpdates       ActionUpdate[]
}

model Initiative {
  id          String    @id @default(cuid())
  createdBy   String
  title       String
  description String?
  status      String    @default("active")
  priority    String    @default("medium")
  progress    Int       @default(0)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator     User                   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  members     InitiativeMember[]
  invitations InitiativeInvitation[]
  settings    InitiativeSettings?
  actions     Action[]
  tags        Tag[]
}

model InitiativeMember {
  id           String   @id @default(cuid())
  userId       String
  initiativeId String
  role         String   @default("member") // owner | admin | member
  department   String?  // Engineering | Sales | Presales | Consultant | Solution | etc.
  joinedAt     DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@unique([userId, initiativeId])
}

model InitiativeInvitation {
  id           String   @id @default(cuid())
  email        String
  initiativeId String
  invitedBy    String
  role         String   @default("member")
  department   String?
  status       String   @default("pending") // pending | joined
  createdAt    DateTime @default(now())
  expiresAt    DateTime?

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  inviter    User       @relation("InvitationSender", fields: [invitedBy], references: [id], onDelete: Cascade)
}

model InitiativeSettings {
  id                  String   @id @default(cuid())
  initiativeId        String   @unique
  emailNotifications  Boolean  @default(true)
  dailyReportEnabled  Boolean  @default(false)
  dailyReportTime     String   @default("09:00")
  dailyReportEmails   String[] @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
}

model Tag {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("#4648d4")
  initiativeId String
  createdAt    DateTime @default(now())

  initiative Initiative  @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  actions    ActionTag[]

  @@unique([name, initiativeId])
}

model Action {
  id           String    @id @default(cuid())
  initiativeId String?
  createdBy    String
  assigneeId   String?
  title        String
  description  String?
  status       String    @default("todo")
  priority     String    @default("medium")
  dueDate      DateTime?
  sourceType   String?
  sourceId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  initiative Initiative? @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  creator    User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  assignee   User?       @relation("ActionAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tags       ActionTag[]
  updates    ActionUpdate[]
}

model ActionTag {
  actionId String
  tagId    String

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([actionId, tagId])
}

model ActionUpdate {
  id        String   @id @default(cuid())
  actionId  String
  userId    String
  content   String
  createdAt DateTime @default(now())

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
