{
  "name": "executive-management-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Executive Management Tool - Full Stack Monorepo",
  "workspaces": [
    "apps/backend",
    "apps/web"
  ],
  "scripts": {
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "build:backend": "cd apps/backend && npm run build",
    "build:web": "cd apps/web && npm run build",
    "db:migrate": "cd apps/backend && npx prisma migrate dev",
    "db:push": "cd apps/backend && npx prisma db push",
    "db:generate": "cd apps/backend && npx prisma generate",
    "db:studio": "cd apps/backend && npx prisma studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
